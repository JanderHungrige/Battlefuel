# BattleFuel environment template. Copy to `.env` and fill real values.
# `.env` is gitignored — NEVER commit real secrets.
#
# Used by:
#   - local dev   (docker-compose.yml: DB credentials)
#   - production  (compose.prod.yml: all services + Caddy TLS + frontend build args)

# --- Database -----------------------------------------------------------------------------
BATTLEFUEL_DB_USER=battlefuel
BATTLEFUEL_DB_PASSWORD=change-me-strong-password
BATTLEFUEL_DB_NAME=battlefuel
# Optional local override of the published DB port (dev only).
BATTLEFUEL_DB_PORT=5432

# --- Backend ------------------------------------------------------------------------------
# Async SQLAlchemy URL. In the prod stack the host is the `db` service name.
BATTLEFUEL_DATABASE_URL=postgresql+asyncpg://battlefuel:change-me-strong-password@db:5432/battlefuel
# CORS origins MUST be a JSON array (parsed by pydantic-settings). Use your real https origin.
BATTLEFUEL_CORS_ORIGINS=["https://battlefuel.example.com"]
# Wave-6 optimizing refuel recommender (prod default).
BATTLEFUEL_REFUEL_RECOMMENDER=ortools

# --- Edge / TLS (Caddy) -------------------------------------------------------------------
# Public domain the stack is served on. Use `localhost` for a local-only smoke test.
BATTLEFUEL_DOMAIN=battlefuel.example.com
# Email Let's Encrypt uses for the ACME account / expiry notices.
BATTLEFUEL_ACME_EMAIL=ops@example.com

# --- Persistence & backups ----------------------------------------------------------------
# Host path for the Postgres data dir. On Hetzner this sits on the mounted block volume
# (feature 40 mounts the volume at /mnt/battlefuel-data). Must exist before `compose up`.
BATTLEFUEL_DB_DATA_DIR=/mnt/battlefuel-data/pgdata
# Where pg_dump backups are written (also on the block volume so they survive host loss).
BATTLEFUEL_BACKUP_DIR=/mnt/battlefuel-data/backups
# Delete backups older than this many days (nightly retention).
BATTLEFUEL_BACKUP_RETENTION_DAYS=14

# --- Frontend build args ------------------------------------------------------------------
# Baked into the frontend image at build time. Must point at the public domain above.
VITE_API_BASE=https://battlefuel.example.com/api/v1
VITE_WS_BASE=wss://battlefuel.example.com/api/v1
