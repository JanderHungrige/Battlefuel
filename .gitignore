# Environment
.env
.env.*
!.env.example
# Deploy env templates are committed; real per-env files (deploy/.env.prod, .env.dev) stay ignored.
!deploy/.env.prod.example
!deploy/.env.dev.example

# Dependencies / build
node_modules/
dist/

# Python
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage

# Generated map-data intermediates (regenerate via backend/scripts/build_basemap.sh)
# The final data/hohenfels.pmtiles IS committed so the app runs offline out-of-the-box.
/data/*.osm
/data/*.osm.pbf
/data/*.geojson

# Frontend: assets copied here by sync:assets from their committed source (don't double-commit)
/frontend/public/hohenfels.pmtiles
/frontend/public/logos/
/frontend/public/docs/

# Claude
CLAUDE.local.md

# Office temp / lock files
~$*

# MDD audit reports (ephemeral — regenerated by /mdd audit)
.mdd/audits/
# MDD active jobs (ephemeral — deleted on completion)
.mdd/jobs/

# macOS
.DS_Store
**/.DS_Store
