# BattleFuel PROD env for compose.app.yml (copy to deploy/.env.prod on the host; gitignored).
# Domain battlefuel.jeanquestenterprise.de -> NPM -> 159.195.148.193:3000
COMPOSE_PROJECT_NAME=battlefuel-prod

REGISTRY=ghcr.io
OWNER=janderhungrige
IMAGE_TAG=main
WATCHTOWER_SCOPE=prod
WATCHTOWER_POLL_INTERVAL=60

APP_PORT=3000

BATTLEFUEL_DB_USER=battlefuel
BATTLEFUEL_DB_PASSWORD=change-me-strong-prod-password
BATTLEFUEL_DB_NAME=battlefuel
BATTLEFUEL_DATABASE_URL=postgresql+asyncpg://battlefuel:change-me-strong-prod-password@db:5432/battlefuel
# Same-origin SPA means CORS usually isn't triggered, but set the real https origin anyway.
# NOTE: unquoted JSON — this file is read only by `docker compose --env-file` (never shell-sourced).
BATTLEFUEL_CORS_ORIGINS=["https://battlefuel.jeanquestenterprise.de"]
BATTLEFUEL_REFUEL_RECOMMENDER=ortools

# Host paths (absolute). Postgres data on a persistent dir; seed .osm extracts for bootstrap.
BATTLEFUEL_DB_DATA_DIR=/opt/battlefuel/data-prod/pgdata
BATTLEFUEL_SEED_DATA_DIR=/opt/battlefuel/data

# Watchtower pull creds for private GHCR images (path to the host docker config.json).
DOCKER_CONFIG_JSON=/root/.docker/config.json
