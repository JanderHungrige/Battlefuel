# BattleFuel DEV env for compose.app.yml (copy to deploy/.env.dev on the host; gitignored).
# Domain battlefuel-dev.jeanquestenterprise.de -> NPM -> 159.195.148.193:3001
COMPOSE_PROJECT_NAME=battlefuel-dev

REGISTRY=ghcr.io
OWNER=janderhungrige
IMAGE_TAG=dev
WATCHTOWER_SCOPE=dev
WATCHTOWER_POLL_INTERVAL=60

APP_PORT=3001

BATTLEFUEL_DB_USER=battlefuel
BATTLEFUEL_DB_PASSWORD=change-me-strong-dev-password
BATTLEFUEL_DB_NAME=battlefuel
BATTLEFUEL_DATABASE_URL=postgresql+asyncpg://battlefuel:change-me-strong-dev-password@db:5432/battlefuel
# Unquoted JSON — read only by `docker compose --env-file` (never shell-sourced).
BATTLEFUEL_CORS_ORIGINS=["https://battlefuel-dev.jeanquestenterprise.de"]
BATTLEFUEL_REFUEL_RECOMMENDER=ortools

BATTLEFUEL_DB_DATA_DIR=/opt/battlefuel/data-dev/pgdata
BATTLEFUEL_SEED_DATA_DIR=/opt/battlefuel/data

DOCKER_CONFIG_JSON=/root/.docker/config.json
